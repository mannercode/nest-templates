{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "⇧⌘Build",
            "group": { "kind": "build", "isDefault": true },
            "type": "shell",
            "command": "npm run build"
        },
        {
            "label": "Tools",
            "type": "shell",
            "command": "bash",
            "args": ["-c", "${input:toolCommand}"]
        },
        {
            "label": "Tests",
            "type": "shell",
            "command": "bash",
            "args": ["-c", "${input:testCommand}"]
        }
    ],
    "inputs": [
        {
            "id": "toolCommand",
            "type": "pickString",
            "description": "tool",
            "options": [
                "npm run clean",
                "npm run lint",
                "npm run format",
                "ncu --deep",
                "ncu --deep -u && npm install"
            ]
        },
        {
            "id": "testCommand",
            "type": "pickString",
            "description": "test",
            "options": [
                "npm run test:unit",
                "npm run test:smoke",
                "npm run test:load -w apis/mono",
                "npm run test:stress -w apis/mono -- sse",
                "npm run test:unit -w libs",
                "npm run test:unit -w apis/mono",
                "npm run test:unit -w apis/msa",
                "npm run test:smoke -w apis/mono",
                "npm run test:smoke -w apis/msa",
                "npm run atoz"
            ]
        }
    ]
}
