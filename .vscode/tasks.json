{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "⇧⌘Build",
            "group": { "kind": "build", "isDefault": true },
            "type": "shell",
            "command": "npm run build"
        },
        {
            "label": "Tools",
            "type": "shell",
            "command": "bash",
            "args": ["-c", "${input:toolCommand}"]
        },
        {
            "label": "Tests",
            "type": "shell",
            "command": "bash",
            "args": ["-c", "${input:testCommand}"]
        }
    ],
    "inputs": [
        {
            "id": "toolCommand",
            "type": "pickString",
            "description": "tool",
            "options": [
                "npm run clean",
                "npm run lint",
                "npm run format",
                "ncu --deep",
                "ncu --deep -u && npm install"
            ]
        },
        {
            "id": "testCommand",
            "type": "pickString",
            "description": "test",
            "options": [
                "npm test",
                "npm test -w libs",
                "npm test -w apis/mono",
                "npm test -w apis/msa",
                "bash apis/mono/deploy/test.sh",
                "bash apis/msa/deploy/test.sh",
                "bash apis/mono/tests/runner.sh sse",
                "npm run atoz",
                "npm run atoz -w apis/mono",
                "npm run atoz -w apis/msa"
            ]
        }
    ]
}
